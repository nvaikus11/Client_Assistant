# Copy to .env and fill in. The real .env is gitignored; this example is committed.

# --- Backend -----------------------------------------------------------------
# How the app talks to Claude. Leave unset for auto:
#   - if ANTHROPIC_API_KEY is set      -> uses the Anthropic API
#   - else if the `claude` CLI exists  -> uses Claude Code (no API key, no API bill)
# Force one explicitly with: api | cli
# EIA_BACKEND=auto

# --- API backend -------------------------------------------------------------
# Only needed for the API backend. Get a key at
# https://console.anthropic.com/settings/keys  (leave blank to use the CLI backend)
ANTHROPIC_API_KEY=

# Optional: default model for tools (override per-tool as needed).
ANTHROPIC_MODEL=claude-opus-4-8
